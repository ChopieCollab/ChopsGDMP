[netfox]

extras/auto_tile_windows=true
extras/screen=1

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"

[steam]

multiplayer_peer/max_channels=4
initialization/app_id=480
initialization/initialize_on_startup=false
initialization/embed_callbacks=true
multiplayer_peer/app_id=0
multiplayer_peer/embed_callbacks=false

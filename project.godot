config_version=5

[application]

config/name="ChopsGDMP"
config/description="A multiplayer framework made for prototyping multiplayer games."
run/main_scene="uid://bx56msakij10t"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

NetworkTime="*uid://cnqdxyjptkfvp"

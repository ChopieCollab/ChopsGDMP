NetworkPerformance="*uid://cqgf7aqmjfoa3"
NetworkManager="*uid://5g5gfjkm31sw"
GameManager="*uid://cek2lqw6nw3om"

[editor_plugins]

enabled=PackedStringArray("res://addons/netfox.internals/plugin.cfg", "res://addons/netfox/plugin.cfg")

[file_customization]

folder_colors={
"res://SteamFoxTest/": "gray",
"res://addons/": "purple",
"res://base classes/": "gray",
"res://critical/": "red",
"res://critical/autoloads/": "pink",
